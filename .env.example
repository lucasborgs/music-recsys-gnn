# --- API do Spotify (necessário apenas para S1 e S2) ---
# Crie suas credenciais em: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=seu_client_id_aqui
SPOTIFY_CLIENT_SECRET=seu_client_secret_aqui
